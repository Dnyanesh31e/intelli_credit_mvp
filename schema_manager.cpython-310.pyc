"""
Comprehensive investment report generator.
"""
from datetime import datetime
from typing import Dict


def generate_investment_report(entity_data: Dict, extracted_data: Dict, 
                               research: Dict, recommendation: Dict, swot: Dict) -> str:
    """
    Generate comprehensive investment/assessment report.
    """
    lines = []
    
    # Header
    lines.append("=" * 100)
    lines.append("COMPREHENSIVE CREDIT ASSESSMENT & INVESTMENT REPORT")
    lines.append("Generated by Intelli-Credit AI Platform")
    lines.append(f"Report Date: {datetime.now().strftime('%B %d, %Y %H:%M')}")
    lines.append("=" * 100)
    lines.append("")
    
    # Executive Summary
    lines.append("EXECUTIVE SUMMARY")
    lines.append("-" * 100)
    basic_info = entity_data.get("basic_info", {})
    loan_details = entity_data.get("loan_details", {})
    
    lines.append(f"Entity Name: {basic_info.get('company_name', 'N/A')}")
    lines.append(f"CIN: {basic_info.get('cin', 'N/A')}")
    lines.append(f"PAN: {basic_info.get('pan', 'N/A')}")
    lines.append(f"Sector: {basic_info.get('sector', 'N/A')}")
    lines.append(f"Annual Turnover: ₹{basic_info.get('turnover', 'N/A')} Cr")
    lines.append("")
    lines.append(f"Loan Type: {loan_details.get('loan_type', 'N/A')}")
    lines.append(f"Loan Amount: ₹{loan_details.get('loan_amount', 'N/A')} Cr")
    lines.append(f"Tenure: {loan_details.get('tenure', 'N/A')} months")
    lines.append(f"Interest Rate: {loan_details.get('interest_rate', 'N/A')}%")
    lines.append("")
    
    # Recommendation
    lines.append("CREDIT RECOMMENDATION")
    lines.append("-" * 100)
    lines.append(f"Recommendation: {recommendation.get('recommendation', 'N/A')}")
    lines.append(f"Confidence Level: {recommendation.get('confidence', 'N/A')}")
    lines.append(f"Overall Score: {recommendation.get('final_score', 0)}/100")
    lines.append(f"  - Financial Score: {recommendation.get('financial_score', 0)}/100")
    lines.append(f"  - Market Score: {recommendation.get('market_score', 0)}/100")
    lines.append("")
    lines.append(f"Rationale: {recommendation.get('rationale', 'N/A')}")
    lines.append("")
    
    # Key Findings
    lines.append("KEY FINDINGS")
    lines.append("-" * 100)
    
    positive_factors = recommendation.get('positive_factors', [])
    if positive_factors:
        lines.append("Positive Factors:")
        for factor in positive_factors:
            lines.append(f"  ✓ {factor}")
        lines.append("")
    
    risk_factors = recommendation.get('risk_factors', [])
    if risk_factors:
        lines.append("Risk Factors:")
        for factor in risk_factors:
            lines.append(f"  ⚠ {factor}")
        lines.append("")
    
    # Financial Analysis
    lines.append("FINANCIAL ANALYSIS")
    lines.append("-" * 100)
    
    # Annual Report
    annual = extracted_data.get("annual_report", {})
    if annual:
        lines.append("Income Statement Highlights:")
        lines.append(f"  Revenue: ₹{annual.get('revenue', 'N/A')} Cr")
        lines.append(f"  EBITDA: ₹{annual.get('ebitda', 'N/A')} Cr")
        lines.append(f"  Net Profit: ₹{annual.get('net_profit', 'N/A')} Cr")
        lines.append("")
        lines.append("Balance Sheet Highlights:")
        lines.append(f"  Total Assets: ₹{annual.get('total_assets', 'N/A')} Cr")
        lines.append(f"  Total Liabilities: ₹{annual.get('total_liabilities', 'N/A')} Cr")
        lines.append(f"  Equity: ₹{annual.get('equity', 'N/A')} Cr")
        lines.append("")
        lines.append("Cash Flow Highlights:")
        lines.append(f"  Operating Cash Flow: ₹{annual.get('operating_cash_flow', 'N/A')} Cr")
        lines.append(f"  Investing Cash Flow: ₹{annual.get('investing_cash_flow', 'N/A')} Cr")
        lines.append(f"  Financing Cash Flow: ₹{annual.get('financing_cash_flow', 'N/A')} Cr")
        lines.append("")
    
    # Borrowing Profile
    borrowing = extracted_data.get("borrowing", {})
    if borrowing:
        lines.append("Borrowing Profile:")
        lines.append(f"  Total Borrowings: ₹{borrowing.get('total_borrowings', 'N/A')} Cr")
        lines.append(f"  Secured Loans: ₹{borrowing.get('secured_loans', 'N/A')} Cr")
        lines.append(f"  Unsecured Loans: ₹{borrowing.get('unsecured_loans', 'N/A')} Cr")
        lines.append(f"  Debt-Equity Ratio: {borrowing.get('debt_equity_ratio', 'N/A')}")
        lines.append(f"  Interest Coverage: {borrowing.get('interest_coverage', 'N/A')}x")
        lines.append("")
    
    # ALM
    alm = extracted_data.get("alm", {})
    if alm:
        lines.append("Asset-Liability Management:")
        lines.append(f"  Total Assets: ₹{alm.get('total_assets', 'N/A')} Cr")
        lines.append(f"  Total Liabilities: ₹{alm.get('total_liabilities', 'N/A')} Cr")
        lines.append(f"  ALM Ratio: {alm.get('alm_ratio', 'N/A')}")
        lines.append(f"  Liquidity Gap: ₹{alm.get('liquidity_gap', 'N/A')} Cr")
        lines.append("")
    
    # Portfolio Quality
    portfolio = extracted_data.get("portfolio", {})
    if portfolio:
        lines.append("Portfolio Quality:")
        lines.append(f"  Portfolio Size: ₹{portfolio.get('portfolio_size', 'N/A')} Cr")
        lines.append(f"  NPA Percentage: {portfolio.get('npa_percentage', 'N/A')}%")
        lines.append(f"  Gross NPA: ₹{portfolio.get('gross_npa', 'N/A')} Cr")
        lines.append(f"  Net NPA: ₹{portfolio.get('net_npa', 'N/A')} Cr")
        lines.append(f"  Provision Coverage: {portfolio.get('provision_coverage', 'N/A')}%")
        lines.append("")
    
    # Shareholding
    shareholding = extracted_data.get("shareholding", {})
    if shareholding:
        lines.append("Shareholding Pattern:")
        lines.append(f"  Promoter Holding: {shareholding.get('promoter_holding', 'N/A')}%")
        lines.append(f"  Public Holding: {shareholding.get('public_holding', 'N/A')}%")
        lines.append(f"  Institutional Holding: {shareholding.get('institutional_holding', 'N/A')}%")
        lines.append(f"  Pledged Shares: {shareholding.get('pledged_shares', 'N/A')}%")
        lines.append("")
    
    # Market Intelligence
    lines.append("MARKET INTELLIGENCE & SECONDARY RESEARCH")
    lines.append("-" * 100)
    
    # News Analysis
    news = research.get("news", [])
    if news:
        lines.append("Recent News & Media Coverage:")
        for item in news[:5]:
            if "error" not in item:
                lines.append(f"  • {item.get('title', 'N/A')} ({item.get('sentiment', 'neutral')})")
                lines.append(f"    Source: {item.get('source', 'N/A')} | Date: {item.get('date', 'N/A')}")
        lines.append("")
    
    # Legal Analysis
    legal = research.get("legal", [])
    if legal:
        lines.append("Legal & Regulatory Status:")
        for item in legal[:5]:
            if "error" not in item:
                lines.append(f"  • {item.get('case_type', 'N/A')} - {item.get('status', 'N/A')}")
                lines.append(f"    Severity: {item.get('severity', 'N/A')} | Date: {item.get('date', 'N/A')}")
        lines.append("")
    
    # Market Sentiment
    sentiment = research.get("market_sentiment", {})
    if sentiment and "error" not in sentiment:
        lines.append("Market Sentiment Analysis:")
        lines.append(f"  Overall Sentiment: {sentiment.get('sentiment', 'N/A').upper()}")
        if "drivers" in sentiment:
            lines.append("  Key Drivers:")
            for driver in sentiment.get("drivers", [])[:3]:
                lines.append(f"    - {driver}")
        if "risks" in sentiment:
            lines.append("  Risk Factors:")
            for risk in sentiment.get("risks", [])[:3]:
                lines.append(f"    - {risk}")
        lines.append("")
    
    # Sector Analysis
    sector_analysis = research.get("sector_analysis", {})
    if sector_analysis and "error" not in sector_analysis:
        lines.append("Sector Analysis:")
        lines.append(f"  Sector: {sector_analysis.get('sector', 'N/A')}")
        lines.append(f"  Growth Rate: {sector_analysis.get('growth_rate', 'N/A')}")
        lines.append(f"  Market Size: {sector_analysis.get('market_size', 'N/A')}")
        lines.append("")
    
    # SWOT Analysis
    lines.append("SWOT ANALYSIS")
    lines.append("-" * 100)
    
    lines.append("Strengths:")
    for strength in swot.get("strengths", []):
        lines.append(f"  ✓ {strength}")
    lines.append("")
    
    lines.append("Weaknesses:")
    for weakness in swot.get("weaknesses", []):
        lines.append(f"  ⚠ {weakness}")
    lines.append("")
    
    lines.append("Opportunities:")
    for opportunity in swot.get("opportunities", []):
        lines.append(f"  → {opportunity}")
    lines.append("")
    
    lines.append("Threats:")
    for threat in swot.get("threats", []):
        lines.append(f"  ✗ {threat}")
    lines.append("")
    
    # Conditions & Monitoring
    if recommendation.get("recommendation") in ["APPROVE", "APPROVE WITH CONDITIONS"]:
        lines.append("LOAN CONDITIONS")
        lines.append("-" * 100)
        conditions = recommendation.get("conditions", [])
        for i, condition in enumerate(conditions, 1):
            lines.append(f"{i}. {condition}")
        lines.append("")
        
        lines.append("MONITORING REQUIREMENTS")
        lines.append("-" * 100)
        monitoring = recommendation.get("monitoring_requirements", [])
        for i, req in enumerate(monitoring, 1):
            lines.append(f"{i}. {req}")
        lines.append("")
    
    # Conclusion
    lines.append("CONCLUSION")
    lines.append("-" * 100)
    lines.append(f"Based on comprehensive analysis of financial data, market intelligence, and")
    lines.append(f"secondary research, the recommendation is to {recommendation.get('recommendation', 'N/A')}.")
    lines.append("")
    lines.append(f"This assessment is based on:")
    lines.append(f"  • Analysis of 5 critical financial documents")
    lines.append(f"  • Secondary research from multiple data sources")
    lines.append(f"  • Market sentiment and sector analysis")
    lines.append(f"  • Comprehensive SWOT analysis")
    lines.append(f"  • Explainable AI-powered risk assessment")
    lines.append("")
    
    # Footer
    lines.append("=" * 100)
    lines.append("END OF REPORT")
    lines.append("")
    lines.append("Disclaimer: This report is generated by AI and should be reviewed by qualified")
    lines.append("credit professionals before making final lending decisions.")
    lines.append("=" * 100)
    
    return "\n".join(lines)
