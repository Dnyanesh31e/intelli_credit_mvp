def generate_cam_memo(analysis: dict, risk_result: dict, classification: dict) -> str:
    """
    Generate a CAM-style credit appraisal memo from analysis results.
    
    Args:
        analysis: LLM analysis output
        risk_result: Risk engine output
        classification: Document classification output
        
    Returns:
        Formatted CAM memo as plain text
    """
    memo_lines = []
    
    # Header
    memo_lines.append("=" * 80)
    memo_lines.append("CREDIT APPRAISAL MEMO")
    memo_lines.append("Generated by Intelli-Credit AI Assistant")
    memo_lines.append("=" * 80)
    memo_lines.append("")
    
    # Company Snapshot
    memo_lines.append("COMPANY SNAPSHOT")
    memo_lines.append("-" * 80)
    memo_lines.append(f"Company Name: {analysis.get('company_name', 'N/A')}")
    memo_lines.append(f"Reporting Period: {analysis.get('reporting_period', 'N/A')}")
    
    company_snapshot = analysis.get('company_snapshot', {})
    if company_snapshot and isinstance(company_snapshot, dict):
        for key, value in company_snapshot.items():
            memo_lines.append(f"{key.replace('_', ' ').title()}: {value}")
    memo_lines.append("")
    
    # Document Classification
    memo_lines.append("DOCUMENT CLASSIFICATION")
    memo_lines.append("-" * 80)
    memo_lines.append(f"Document Type: {classification.get('document_type', 'unknown')}")
    memo_lines.append(f"Classification Confidence: {classification.get('confidence', 0.0)}")
    matched_rules = classification.get('matched_rules', [])
    if matched_rules:
        memo_lines.append(f"Matched Keywords: {', '.join(matched_rules[:5])}")
    memo_lines.append("")
    
    # Key Extracted Signals
    memo_lines.append("KEY EXTRACTED SIGNALS")
    memo_lines.append("-" * 80)
    key_signals = analysis.get('key_signals', [])
    if key_signals:
        for i, signal in enumerate(key_signals, 1):
            memo_lines.append(f"{i}. {signal}")
    else:
        memo_lines.append("No key signals extracted")
    memo_lines.append("")
    
    # Financial Highlights
    memo_lines.append("FINANCIAL HIGHLIGHTS")
    memo_lines.append("-" * 80)
    financial_metrics = analysis.get('financial_metrics', {})
    if financial_metrics and isinstance(financial_metrics, dict):
        for key, value in financial_metrics.items():
            memo_lines.append(f"{key.replace('_', ' ').title()}: {value}")
    else:
        memo_lines.append("No financial metrics available")
    memo_lines.append("")
    
    # Governance Highlights
    memo_lines.append("GOVERNANCE HIGHLIGHTS")
    memo_lines.append("-" * 80)
    governance_metrics = analysis.get('governance_metrics', {})
    if governance_metrics and isinstance(governance_metrics, dict):
        for key, value in governance_metrics.items():
            memo_lines.append(f"{key.replace('_', ' ').title()}: {value}")
    else:
        memo_lines.append("No governance metrics available")
    memo_lines.append("")
    
    # Compliance Flags
    memo_lines.append("COMPLIANCE FLAGS")
    memo_lines.append("-" * 80)
    compliance_flags = analysis.get('compliance_flags', [])
    if compliance_flags:
        for i, flag in enumerate(compliance_flags, 1):
            memo_lines.append(f"{i}. {flag}")
    else:
        memo_lines.append("No compliance flags")
    memo_lines.append("")
    
    # Risk Flags
    memo_lines.append("RISK FLAGS")
    memo_lines.append("-" * 80)
    risk_flags = analysis.get('risk_flags', [])
    if risk_flags:
        for i, flag in enumerate(risk_flags, 1):
            memo_lines.append(f"{i}. {flag}")
    else:
        memo_lines.append("No risk flags identified")
    memo_lines.append("")
    
    # Positive Signals
    positive_signals = analysis.get('positive_signals', [])
    if positive_signals:
        memo_lines.append("POSITIVE SIGNALS")
        memo_lines.append("-" * 80)
        for i, signal in enumerate(positive_signals, 1):
            memo_lines.append(f"{i}. {signal}")
        memo_lines.append("")
    
    # Final Risk Assessment
    memo_lines.append("FINAL RISK ASSESSMENT")
    memo_lines.append("-" * 80)
    memo_lines.append(f"Risk Score: {risk_result.get('final_score', 0)}/100")
    memo_lines.append(f"Risk Level: {risk_result.get('risk_level', 'Unknown')}")
    memo_lines.append("")
    memo_lines.append("Score Breakdown:")
    score_breakdown = risk_result.get('score_breakdown', [])
    if score_breakdown:
        for item in score_breakdown:
            memo_lines.append(f"  • {item}")
    else:
        memo_lines.append("  • Base score: 50")
    memo_lines.append("")
    
    # Recommendation
    memo_lines.append("RECOMMENDATION")
    memo_lines.append("-" * 80)
    memo_lines.append(f"Credit Decision: {risk_result.get('recommendation', 'Review')}")
    memo_lines.append("")
    
    # Analyst Note
    memo_lines.append("ANALYST NOTE")
    memo_lines.append("-" * 80)
    cam_summary = analysis.get('cam_summary', '')
    if cam_summary:
        memo_lines.append(cam_summary)
    else:
        memo_lines.append("No additional analyst notes.")
    memo_lines.append("")
    
    # Footer
    memo_lines.append("=" * 80)
    memo_lines.append("END OF CREDIT APPRAISAL MEMO")
    memo_lines.append("=" * 80)
    
    return "\n".join(memo_lines)
